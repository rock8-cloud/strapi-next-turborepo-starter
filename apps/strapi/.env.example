# Server
HOST=0.0.0.0
PORT=1337
# Public URL of this Strapi instance (the strapi service URL on Rock8Cloud).
# Used for seeded links (e.g. the "CMS Admin" navbar item → $PUBLIC_URL/admin).
# Leave unset locally → defaults to http://localhost:1337.
# PUBLIC_URL=

# Secrets — generate real values, e.g. `openssl rand -base64 16` for each
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
ENCRYPTION_KEY=tobemodified

# Database (PostgreSQL)
# Option A — single connection string. On Rock8Cloud, link the managed
# PostgreSQL service's `URL` variable to DATABASE_URL. Takes precedence
# over the discrete vars below.
# DATABASE_URL=postgresql://strapi:strapi@localhost:5432/strapi
# Option B — discrete vars (local docker-compose defaults):
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false

# Media uploads
# Leave S3_* unset for local development → files are stored on the local
# filesystem (public/uploads). In deployment, link the Rock8Cloud S3 Object
# Storage service — its exposed variable names match these exactly:
# S3_ENDPOINT=
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_URL=

# Live preview
# Public URL of the Next.js frontend (the web service URL on Rock8Cloud).
CLIENT_URL=http://localhost:3000
# Shared secret — must match PREVIEW_SECRET in the web app.
PREVIEW_SECRET=dev-preview-secret
