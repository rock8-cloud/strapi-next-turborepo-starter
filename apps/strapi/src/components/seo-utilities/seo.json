{
  "collectionName": "components_seo_utilities_seos",
  "info": {
    "displayName": "SEO",
    "icon": "search",
    "description": "Per-page metadata: title, description, social image, robots"
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "maxLength": 60
    },
    "metaDescription": {
      "type": "string",
      "maxLength": 160
    },
    "metaImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "canonicalUrl": {
      "type": "string"
    },
    "metaRobots": {
      "type": "enumeration",
      "default": "all",
      "enum": ["all", "noindex", "noindex,nofollow"]
    }
  }
}